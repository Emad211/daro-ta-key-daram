<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!--
      Medication names, schedules, stock, notes, and history remain local-only.
      Backup/export stays disabled until the product has an explicit encrypted,
      consented, and recoverable backup design.
    -->
    <exclude domain="root" path="." />
    <exclude domain="file" path="." />
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
