  "fixed_sql": [
    {
      "name": "medications",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"medications\" (\"id\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"unit\" TEXT NOT NULL, \"units_per_day\" REAL NOT NULL CHECK (units_per_day > 0), \"consumption_schedule_json\" TEXT NULL, \"alert_lead_days\" INTEGER NOT NULL DEFAULT 5 CHECK (alert_lead_days BETWEEN 0 AND 365), \"notes\" TEXT NULL, \"is_archived\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_archived\" IN (0, 1)), \"created_at\" INTEGER NOT NULL, \"updated_at\" INTEGER NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "inventory_events",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"inventory_events\" (\"id\" TEXT NOT NULL, \"medication_id\" TEXT NOT NULL REFERENCES medications (id) ON DELETE CASCADE, \"event_type\" TEXT NOT NULL, \"stock_units\" REAL NOT NULL CHECK (stock_units >= 0), \"effective_at\" INTEGER NOT NULL, \"created_at\" INTEGER NOT NULL, \"note\" TEXT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "app_preferences",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"app_preferences\" (\"key\" TEXT NOT NULL, \"value\" TEXT NOT NULL, \"updated_at\" INTEGER NOT NULL, PRIMARY KEY (\"key\"));"
        }
      ]
    },
    {
      "name": "ad_frequency_caps",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"ad_frequency_caps\" (\"placement\" TEXT NOT NULL, \"meaningful_actions\" INTEGER NOT NULL DEFAULT 0, \"last_shown_at\" INTEGER NULL, \"day_key\" TEXT NOT NULL, \"shown_today\" INTEGER NOT NULL DEFAULT 0, PRIMARY KEY (\"placement\"));"
        }
      ]
    },
